# Shift Code Bot Configuration Template
# Copy this file to .env and fill in your values

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/shift_codes.db

# Discord Configuration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Reddit Configuration (Optional)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=ShiftCodeBot/2.0

# Monitoring and Alerting
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ALERT_WEBHOOK_ID/YOUR_ALERT_WEBHOOK_TOKEN

# Scheduler Configuration
CRON_SCHEDULE=*/10 * * * *
MAX_EXECUTION_TIME=300

# Rate Limiting
REQUESTS_PER_MINUTE=60
DELAY_BETWEEN_REQUESTS=1.0

# Health Check
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_ENABLED=true

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *