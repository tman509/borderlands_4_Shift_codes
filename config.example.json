{
  "database_url": "sqlite:///shift_codes.db",
  "environment": "development",
  "debug": false,
  "timezone": "UTC",
  "sources": [
    {
      "id": 1,
      "name": "Official Gearbox Twitter",
      "url": "https://twitter.com/GearboxOfficial",
      "type": "html",
      "enabled": true,
      "parser_hints": {
        "selectors": [".tweet-text", ".content"],
        "fallback_regex": true
      },
      "rate_limit": {
        "requests_per_minute": 30,
        "delay_between_requests": 2.0,
        "burst_limit": 5
      }
    },
    {
      "id": 2,
      "name": "Borderlands Subreddit",
      "url": "https://www.reddit.com/r/borderlands3",
      "type": "reddit",
      "enabled": true,
      "parser_hints": {
        "subreddit": "borderlands3",
        "post_limit": 25,
        "include_comments": true
      },
      "rate_limit": {
        "requests_per_minute": 60,
        "delay_between_requests": 1.0,
        "burst_limit": 10
      }
    }
  ],
  "discord_channels": [
    {
      "id": "main",
      "name": "Main Channel",
      "webhook_url": "https://discord.com/api/webhooks/YOUR_WEBHOOK_URL",
      "enabled": true,
      "message_template": null,
      "source_filters": []
    }
  ],
  "notification_settings": {
    "max_codes_per_notification": 5,
    "enable_expiration_reminders": true,
    "reminder_hours_before": 24,
    "rate_limit_delay": 0.5,
    "max_retries": 3
  },
  "scheduler_config": {
    "cron_schedule": "*/10 * * * *",
    "enable_manual_trigger": true,
    "max_execution_time": 300
  },
  "observability_config": {
    "log_level": "INFO",
    "log_format": "json",
    "metrics_enabled": true,
    "health_check_enabled": true,
    "alert_webhook_url": null
  }
}